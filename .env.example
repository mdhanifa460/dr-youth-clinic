# ============================================================
# DR Youth Clinic — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================================

# ------------------------------------------------------------
# DATABASE
# Required. MongoDB Atlas connection string.
# MONGODB_DB_NAME is optional — defaults to 'clinicDB' (production).
# Set it to a different database name locally (e.g. clinicDB_dev) to
# test against a copy of your data without touching production content.
# Leave it unset in Vercel Production.
# ------------------------------------------------------------
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_DB_NAME=clinicDB

# ------------------------------------------------------------
# ADMIN AUTH
# Required. Credentials for the /admin portal.
# ADMIN_SESSION_SECRET must be a long random string (32+ chars).
# Generate one with: openssl rand -hex 32
# (NEXTAUTH_SECRET is accepted as a legacy fallback if
# ADMIN_SESSION_SECRET is unset, but don't rely on it — set
# ADMIN_SESSION_SECRET explicitly instead.)
# ------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-this-to-a-random-32-char-string

# ------------------------------------------------------------
# CLOUDINARY — image storage & delivery
# Required. Find these in your Cloudinary dashboard.
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME is exposed to the browser.
# ------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ------------------------------------------------------------
# WHATSAPP BUSINESS API — appointment notifications
# Required if booking flow is enabled.
# PHONE_NUMBER_ID: WhatsApp Business phone number ID
# WHATSAPP_TOKEN: permanent access token from Meta
# CLINIC_PHONE: display number shown to patients (e.g. +919876543210)
# ------------------------------------------------------------
PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_TOKEN=your_whatsapp_token
CLINIC_PHONE=+91XXXXXXXXXX

# ------------------------------------------------------------
# LANDING PAGE LEAD NOTIFICATIONS — separate from the Business API above
# Optional, but required for the "WhatsApp Notify" toggle on individual
# landing pages (Admin → Landing Pages → a page → Form settings) to
# actually do anything. If unset, that toggle silently does nothing —
# no error is shown anywhere when a lead comes in.
# Digits only, no "+" (e.g. 919876543210), since it's used in a
# wa.me/api.whatsapp.com deep link, not the Business API.
# ------------------------------------------------------------
WHATSAPP_NOTIFY_NUMBER=919876543210

# ------------------------------------------------------------
# SITE URL — used for canonical URLs, OG tags, sitemaps
# Required in production. Leave empty in preview deploys
# (Vercel sets VERCEL_URL automatically for previews).
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com

# ------------------------------------------------------------
# GOOGLE PLACES API — optional Google Reviews sync
# If not set, the "Sync from Google" button is disabled gracefully.
# ------------------------------------------------------------
GOOGLE_PLACES_API_KEY=your_google_places_api_key
GOOGLE_PLACE_ID=your_google_place_id

# ------------------------------------------------------------
# AI — used for admin Business Intelligence features
# Optional. If not set, AI analysis is disabled gracefully.
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ------------------------------------------------------------
# RESEND — outbound email (skin quiz "email me my plan")
# Optional. If not set, the quiz still saves the lead and notifies
# the clinic via WhatsApp, but no email is sent to the patient —
# the UI then shows "we'll reach out to you" instead of "check your inbox."
# Get a key at resend.com. RESEND_FROM_EMAIL defaults to Resend's
# onboarding@resend.dev test sender, which works without verifying a
# domain but should be replaced with a verified address for production
# (e.g. "DR Youth Clinic <plans@yourdomain.com>") for better deliverability.
# ------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=DR Youth Clinic <onboarding@resend.dev>

# ============================================================
# DEPLOYMENT NOTES
# ============================================================
# Vercel Production:
#   Set all variables above in Project Settings → Environment Variables.
#   Tick "Production" environment. Set NEXT_PUBLIC_SITE_URL to the
#   primary domain (e.g. https://www.yourdomain.com).
#
# Vercel Preview:
#   Tick "Preview" environment for all variables EXCEPT NEXT_PUBLIC_SITE_URL
#   (leave it unset so previews use relative URLs instead of the prod domain).
#
# Local development (.env.local):
#   Copy this file, rename to .env.local, fill in real values.
#   .env.local is git-ignored and never committed.
#
# MISSING BEFORE DEPLOYMENT — set these or the app will break:
#   MONGODB_URI           — no DB = 500 errors on every page
#   ADMIN_EMAIL           — can't log in to admin
#   ADMIN_PASSWORD        — can't log in to admin
#   ADMIN_SESSION_SECRET  — sessions signed with weak fallback
#   NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME — images won't load
#   CLOUDINARY_API_KEY    — image uploads fail
#   CLOUDINARY_API_SECRET — image uploads fail
# ============================================================
